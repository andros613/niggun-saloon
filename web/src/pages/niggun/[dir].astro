---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import { loadCatalog } from '../../lib/catalog';
import type { Niggun } from '../../lib/catalog';
import { tagLabel } from '../../lib/tags';

export async function getStaticPaths() {
  const catalog = loadCatalog();
  return catalog.nigguns.map(n => ({ params: { dir: n.dir }, props: { niggun: n } }));
}

interface Props { niggun: Niggun }
const { niggun: n } = Astro.props;

// Look up parent and arrangement details at build time
const catalog = loadCatalog();
const parentNiggun = n.variant_of ? catalog.nigguns.find(p => p.id === n.variant_of) ?? null : null;
const pianoDetails  = n.piano_arrangements.map(dir => catalog.nigguns.find(x => x.dir === dir)).filter(Boolean) as Niggun[];
const choralDetails = n.choral_arrangements.map(dir => catalog.nigguns.find(x => x.dir === dir)).filter(Boolean) as Niggun[];

// Load lyrics files from disk at build time
const dataRoot = path.resolve(process.cwd(), '..', 'data', n.dir);

function readLyrics(filename: string): string | null {
  const p = path.join(dataRoot, filename);
  return fs.existsSync(p) ? fs.readFileSync(p, 'utf-8').trim() : null;
}

const wordsHe    = n.assets.has_words_he      ? readLyrics('words_he.txt')      : null;
const wordsEn    = n.assets.has_words_en      ? readLyrics('words_en.txt')      : null;
const wordsTh    = n.assets.has_words_th_en   ? readLyrics('words_th_en.txt')   : null;
const wordsAshk  = n.assets.has_words_as_ashk ? readLyrics('words_as_ashk.txt') : null;

// GitHub Releases asset URLs (placeholder — CI will populate these)
// For now: look for the files locally and reference them via public copy
// In production these will be Release CDN URLs stored in metadata.json asset_urls
const base = import.meta.env.BASE_URL;

// Stem detection — find the .ly filename stem for building asset names
const dataDir = path.resolve(process.cwd(), '..', 'data', n.dir);
const lyFile = fs.readdirSync(dataDir).find(f => f.endsWith('.ly')) ?? '';
const stem = lyFile.replace('.ly', '');

// Asset URLs: served from public/ for now; will be Release CDN URLs in CI
// The CI workflow will copy/symlink assets into web/public/assets/<dir>/
function assetUrl(ext: string): string | null {
  const filename = stem ? `${stem}.${ext}` : null;
  if (!filename) return null;
  const localPath = path.join(dataDir, filename);
  return fs.existsSync(localPath) ? `${base}assets/${n.dir}/${filename}` : null;
}


function sourceName(url: string): string {
  const domain = new URL(url).hostname.replace(/^www\./, '');
  const names: Record<string, string> = {
    'chabad.org':            'Chabad.org',
    'sefaria.org':           'Sefaria.org',
    'sefaria.org.il':        'Sefaria.org',
    'aish.com':              'Aish.com',
    'zemirotdatabase.org':   'Zemirot Database',
    'alittlehebrew.com':     'A Little Hebrew',
    'anash.org':             'Anash.org',
    'crownheights.info':     'CrownHeights.info',
    'youtube.com':           'YouTube',
    'youtu.be':              'YouTube',
  };
  return names[domain] ?? domain;
}

const mp3Url  = n.assets.has_mp3  ? assetUrl('mp3')  : null;
const pdfUrl  = n.assets.has_pdf  ? assetUrl('pdf')  : null;
const midiUrl = n.assets.has_midi ? assetUrl('midi') : null;
const lyUrl   = n.assets.has_ly   ? assetUrl('ly')   : null;
---

<Layout
  title={n.title}
  description={n.subtitle || `${n.title} — arranged by ${n.arranger}`}
>
  <div class="niggun-detail">
    {parentNiggun && (
      <div class="back-link">
        <a href={`${base}niggun/${parentNiggun.dir}/`}>← {parentNiggun.title}</a>
      </div>
    )}

    <div>
      <h1>{n.title}</h1>
      {n.subtitle && <p class="sub">{n.subtitle}</p>}
      <div class="detail-tags">
        {n.arrangement_type === 'piano'  && <span class="tag tag-has-piano">🎹 Piano Arrangement</span>}
        {n.arrangement_type === 'choral' && <span class="tag tag-has-choral">🎼 Choral Arrangement</span>}
        {n.tags.map(t => (
          <span class={`tag tag-${t}`}>{tagLabel(t)}</span>
        ))}
      </div>
    </div>

    <div class="meta-row">
      {n.key         && <span>🎼 {n.key}</span>}
      {n.tempo_bpm   && <span>♩= {n.tempo_bpm} bpm</span>}
      {n.arranger    && <span>✍️ {n.arranger}</span>}
      {n.date_gregorian && <span>📅 {n.date_gregorian}{n.date_hebrew ? ` / ${n.date_hebrew}` : ''}</span>}
      {n.version     && <span>{n.version}</span>}
      {n.license     && <span>{n.license}</span>}
    </div>

    {n.description && (
      <p>{n.description}</p>
    )}

    {mp3Url && (
      <div class="audio-section">
        <h2>Listen</h2>
        <audio
          id="audio-player"
          controls
          src={mp3Url}
          data-title={n.title}
          data-artist={n.arranger ?? ''}
          data-artwork={`${base}temple_v02.png`}
        />
        <div class="speed-controls">
          <label for="speed-select">Speed:</label>
          <select id="speed-select">
            {[0.5, 0.75, 1, 1.25, 1.5, 1.75, 2].map(s => (
              <option value={s} selected={s === 1}>{s}x</option>
            ))}
          </select>
        </div>
      </div>
    )}

    <div class="download-links">
      {mp3Url  && <a href={mp3Url}  download>🎵 Download MP3</a>}
      {pdfUrl  && <a href={pdfUrl}  download>📄 Download PDF</a>}
      {midiUrl && <a href={midiUrl} download>🎹 Download MIDI</a>}
      {lyUrl   && <a href={lyUrl}   download>🎼 Download LilyPond</a>}
    </div>

    {pdfUrl && (
      <div class="pdf-viewer">
        <h2>Sheet Music</h2>
        <div class="pdf-wrapper" id="pdf-wrapper">
          <iframe id="pdf-iframe" src={pdfUrl} title={`${n.title} sheet music`} />
        </div>
        <div class="pdf-zoom-controls">
          <button id="pdf-zoom-out" aria-label="Zoom out">−</button>
          <span id="pdf-zoom-label">100%</span>
          <button id="pdf-zoom-in" aria-label="Zoom in">+</button>
        </div>
      </div>
    )}

    {n.references.length > 0 && (
      <div class="references">
        <h2>Sources &amp; References</h2>
        <div class="ref-list">
          {n.references.map(ref => (
            <div class="ref-item">
              {ref.type === 'youtube' && ref.embed_id ? (
                <div class="ref-embed">
                  {ref.label && <p class="ref-label">{ref.label}</p>}
                  <iframe
                    src={`https://www.youtube.com/embed/${ref.embed_id}`}
                    title={ref.label ?? 'YouTube video'}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                </div>
              ) : (
                <a href={ref.url} target="_blank" rel="noopener noreferrer" class="ref-link">
                  <span class="ref-icon">
                    {ref.type === 'chabad_media' ? '🎵' : '🔗'}
                  </span>
                  <span>
                    {ref.label ?? ref.url}
                    <span class="ref-source"> (from {sourceName(ref.url)})</span>
                  </span>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}

    {(wordsHe || wordsEn || wordsTh || wordsAshk) && (
      <div>
        <h2>Lyrics</h2>
        <div class="lyrics-pane">
          {wordsHe && (
            <div class="lyrics-col">
              <h3>Hebrew</h3>
              <pre class="he">{wordsHe}</pre>
            </div>
          )}
          {wordsTh && (
            <div class="lyrics-col">
              <h3>Transliteration (TH)</h3>
              <pre>{wordsTh}</pre>
            </div>
          )}
          {wordsAshk && (
            <div class="lyrics-col">
              <h3>Transliteration (ArtScroll)</h3>
              <pre>{wordsAshk}</pre>
            </div>
          )}
          {wordsEn && (
            <div class="lyrics-col">
              <h3>English</h3>
              <pre>{wordsEn}</pre>
            </div>
          )}
        </div>
      </div>
    )}
    {(pianoDetails.length > 0 || choralDetails.length > 0) && (
      <div class="arrangements">
        {pianoDetails.length > 0 && (
          <div>
            <h2>Piano Arrangements</h2>
            <div class="arrangement-list">
              {pianoDetails.map(arr => (
                <a href={`${base}niggun/${arr.dir}/`} class="arrangement-card">
                  <span class="tag tag-has-piano">🎹 Piano</span>
                  <span class="arr-title">{arr.title || arr.dir}</span>
                  {arr.key && <span class="arr-meta">{arr.key}</span>}
                  {arr.arranger && <span class="arr-meta">✍️ {arr.arranger}</span>}
                </a>
              ))}
            </div>
          </div>
        )}
        {choralDetails.length > 0 && (
          <div>
            <h2>Choral Arrangements</h2>
            <div class="arrangement-list">
              {choralDetails.map(arr => (
                <a href={`${base}niggun/${arr.dir}/`} class="arrangement-card">
                  <span class="tag tag-has-choral">🎼 Choral</span>
                  <span class="arr-title">{arr.title || arr.dir}</span>
                  {arr.key && <span class="arr-meta">{arr.key}</span>}
                  {arr.arranger && <span class="arr-meta">✍️ {arr.arranger}</span>}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>

<script>
  // Lock-screen / media session metadata (artwork, title, artist for iOS/Android)
  const audio = document.getElementById('audio-player') as HTMLAudioElement | null;
  if (audio && 'mediaSession' in navigator) {
    const artworkSrc = new URL(audio.dataset.artwork ?? '', location.href).href;
    const metadata = new MediaMetadata({
      title:  audio.dataset.title  ?? '',
      artist: audio.dataset.artist ?? '',
      artwork: [{ src: artworkSrc, type: 'image/png' }],
    });
    audio.addEventListener('play', () => { navigator.mediaSession.metadata = metadata; }, { once: true });
  }

  // Playback speed
  const select = document.getElementById('speed-select') as HTMLSelectElement | null;
  select?.addEventListener('change', () => {
    if (audio) audio.playbackRate = parseFloat(select.value);
  });

  // Spacebar play/pause; arrow keys seek ±5s (skip if focus is on an input/button)
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.code !== 'Space' && e.code !== 'ArrowLeft' && e.code !== 'ArrowRight') return;
    const tag = (e.target as HTMLElement).tagName;
    if (tag === 'INPUT' || tag === 'SELECT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;
    if (!audio) return;
    e.preventDefault();
    if (e.code === 'Space') {
      audio.paused ? audio.play() : audio.pause();
    } else if (e.code === 'ArrowLeft') {
      audio.currentTime = Math.max(0, audio.currentTime - 5);
    } else if (e.code === 'ArrowRight') {
      audio.currentTime = Math.min(audio.duration, audio.currentTime + 5);
    }
  });

  // PDF zoom
  const iframe  = document.getElementById('pdf-iframe')    as HTMLIFrameElement | null;
  const wrapper = document.getElementById('pdf-wrapper')   as HTMLDivElement | null;
  const label   = document.getElementById('pdf-zoom-label') as HTMLSpanElement | null;
  const zoomIn  = document.getElementById('pdf-zoom-in')   as HTMLButtonElement | null;
  const zoomOut = document.getElementById('pdf-zoom-out')  as HTMLButtonElement | null;

  let zoom = 1.0;
  const STEP = 0.25;
  const MIN = 0.5;
  const MAX = 3.0;

  function applyZoom() {
    if (!iframe || !wrapper) return;
    iframe.style.transform = `scale(${zoom})`;
    // Expand the wrapper so the scaled content doesn't get clipped
    iframe.style.width  = `${100 / zoom}%`;
    iframe.style.height = `${100 / zoom}%`;
    if (label) label.textContent = `${Math.round(zoom * 100)}%`;
  }

  zoomIn?.addEventListener('click',  () => { zoom = Math.min(MAX, zoom + STEP); applyZoom(); });
  zoomOut?.addEventListener('click', () => { zoom = Math.max(MIN, zoom - STEP); applyZoom(); });
</script>
