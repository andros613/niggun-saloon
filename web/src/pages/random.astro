---
import Layout from '../layouts/Layout.astro';
import { loadCatalog } from '../lib/catalog';

const catalog = loadCatalog();
// Only top-level nigguns (no arrangements), same filter as browse page
const dirs = catalog.nigguns
  .filter(n => n.arrangement_type === null)
  .map(n => n.dir);

const base = import.meta.env.BASE_URL;
---

<Layout title="Random Niggun">
  <p style="text-align:center;margin-top:4rem;opacity:0.6;">Finding a random niggun…</p>
</Layout>

<script define:vars={{ dirs, base }}>
  const dir = dirs[Math.floor(Math.random() * dirs.length)];
  window.location.replace(`${base}niggun/${dir}/`);
</script>
