---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Niggun Saloon — Jewish liturgical music arrangements' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title} | Niggun Saloon</title>
  </head>
  <body>
    <header class="site-header">
      <a href={base}>🎵 Niggun Saloon</a>
      <nav>
        <a href={base}>Browse</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
