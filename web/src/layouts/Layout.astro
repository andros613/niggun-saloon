---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Niggun Saloon — Jewish liturgical music arrangements' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <title>{title} | Niggun Saloon</title>
  </head>
  <body>
    <header class="site-header">
      <a href="https://andros613.github.io/">andros613: Jewish Learning Hub</a>
      <span class="site-header-sep">›</span>
      <a href={base} class="site-tool-name">🎵 Niggun Saloon</a>
      <nav>
        <a href={base}>Browse</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">

        <div class="footer-col">
          <p class="footer-heading">Found a bug?</p>
          <a
            class="footer-link"
            href="https://github.com/andros613/niggun-saloon/issues/new"
            target="_blank"
            rel="noopener noreferrer"
          >Open a GitHub issue</a>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Feedback &amp; suggestions</p>
          <a
            class="footer-link"
            href="https://tally.so/r/rjd67M"
            target="_blank"
            rel="noopener noreferrer"
          >Share your thoughts</a>
        </div>

        <div class="footer-col footer-subscribe">
          <p class="footer-heading">Stay updated</p>
          <form
            action="https://buttondown.com/api/emails/embed-subscribe/andros613"
            method="post"
            class="subscribe-form"
          >
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              class="subscribe-input"
              autocomplete="email"
            />
            <button type="submit" class="subscribe-btn">Subscribe</button>
          </form>
        </div>

      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
